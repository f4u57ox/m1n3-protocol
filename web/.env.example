# m1n3 web frontend — environment variables
# Copy to web/.env.local and fill in values for your deployment.

# Active m1n3_v4 package ID (matches contracts/Published.toml [published.mainnet] published-at)
NEXT_PUBLIC_PACKAGE_ID=0x8377b3f15d11eb6debf1afba251e1c275cd130e0ca48ba86b88f953324ae0605

# Original (immutable) package ID — event type prefix
NEXT_PUBLIC_ORIGINAL_PACKAGE_ID=0xdf7cc2d80454cd56818e58e727b48beb2f8c441fcf6e4f46fd2282d24427a895

# Sui RPC and network
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
NEXT_PUBLIC_SUI_NETWORK=mainnet

# m1n3 shared object IDs — set after `sui client publish` returns the freshly-shared
# objects. PoolAdminCap is owned by the deploying wallet (not shared).
NEXT_PUBLIC_POOL_OBJECT_ID=
NEXT_PUBLIC_POOL_ADMIN_CAP_ID=
NEXT_PUBLIC_HASHI_REWARD_REGISTRY_ID=
NEXT_PUBLIC_HASHI_POOL_CONFIG_ID=
NEXT_PUBLIC_SHARE_DEDUP_REGISTRY_ID=

# Coin type used for HashiVault<T>, HashiRewardBatch<T>, claim_reward<T>.
# Must match the BTC type Hashi mints (e.g. `0x…::btc::BTC`). The rewards
# page passes this as the generic argument when building the claim PTB,
# so the on-chain type check `<batch.CoinType> == <claim.CoinType>` holds.
NEXT_PUBLIC_HBTC_COIN_TYPE=0x2::sui::SUI

# HashShare market — `hash_share_market::MarketFeePool` shared object,
# minted at package init. The /marketplace page's fill_buy_order and
# fill_sell_order paths require this so the 2% market fee is routed to
# the right admin wallet on every fill.
NEXT_PUBLIC_HASH_SHARE_MARKET_FEE_POOL_ID=

# Optional: DeepBookV3 pool explorer base URL. If set, the /rewards page
# renders a "DeepBook" link next to each HashShare balance pointing at
# `${BASE}/${coin_type}`. Leave empty to hide.
NEXT_PUBLIC_DEEPBOOK_POOL_EXPLORER_BASE=
