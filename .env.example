# m1n3 full Stratum/Sui configuration

# Bitcoin Core RPC. Prefer embedding credentials here instead of CLI args so
# they do not show up in process listings.
BITCOIN_RPC_URL=http://<rpc-user>:<rpc-password>@127.0.0.1:8332

# Sui network / package objects
SUI_RPC_URL=https://fullnode.devnet.sui.io:443
SUI_KEYSTORE=$HOME/.sui/sui_config/sui.keystore
SUI_PACKAGE=<published_m1n3_v4_package_id>
POOL_OBJECT=<pool_shared_object_id>
TEMPLATE_REGISTRY=<template_registry_shared_object_id>
POOL_ADMIN_CAP=

# Optional Bitcoin payout scriptPubKey hex for coinbase construction.
# Examples:
#   P2WPKH: 0014<20-byte-hash>
#   P2TR:  5120<32-byte-xonly-pubkey>
POOL_ADDRESS=<hex_script_pubkey>

# Stratum server
STRATUM_PORT=3333
METRICS_PORT=9091
INITIAL_DIFFICULTY=4096
TARGET_SHARES_PER_MIN=10

# ── DeepBookV3 integration (HashShare market) ────────────────────────────────
# trustless-keeper subscribes to `hash_share_registry::SlotBoundToRound` and
# creates a permissionless DeepBook pool per HashShare slot. All four
# variables below must be set for the keeper to actually submit the
# pool-creation PTB; otherwise it dry-runs that tick (the rest still works).
#
# Canonical IDs are pinned by Mysten on mainnet. Current values (version 6,
# verified 2026-06-18):
#
#   DEEPBOOK_PACKAGE_ID=0x337f4f4f6567fcd778d5454f27c16c70e2f274cc6377ea6249ddf491482ef497
#   DEEPBOOK_REGISTRY_ID=0xaf16199a2dff736e9f07a845f23c5da6df6f756eddb631aed9d24a93efc4549d
#
# Quote-coin and DEEP token addresses depend on which Sui-native coin you
# want HashShares paired with. Common pairs:
#   USDC (Mysten):   0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
#   DEEP (Mysten):   0xdeeb7a4662eec9f2f3def03fb937a663dddaa2e215b8078a284d026b7946c270::deep::DEEP
# Cross-check before relying on them — the canonical references live at
# https://docs.sui.io/standards/deepbookv3 .
#
# Devnet: DeepBookV3 is not deployed on devnet; the keeper will dry-run
# this tick and continue with the rest of the pipeline.
#
DEEPBOOK_PACKAGE_ID=0x337f4f4f6567fcd778d5454f27c16c70e2f274cc6377ea6249ddf491482ef497
DEEPBOOK_REGISTRY_ID=0xaf16199a2dff736e9f07a845f23c5da6df6f756eddb631aed9d24a93efc4549d
DEEPBOOK_QUOTE_COIN_TYPE=
DEEPBOOK_DEEP_COIN_ID=
DEEPBOOK_TICK_SIZE=1
DEEPBOOK_LOT_SIZE=1
DEEPBOOK_MIN_SIZE=1

# Miner sidecar, for trustless miner-signed Sui submission.
STRATUM_HOST=127.0.0.1:3333
LISTEN_PORT=3334
DEDUP_REGISTRY=
BATCH_SIZE=16
BATCH_TIMEOUT_MS=5000

# Logging
RUST_LOG=info
