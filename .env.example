# ── Pool operator (stratum-bridge) ────────────────────────────────────────────

# Stratum server listen address
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3333

# Sui network
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Operator credentials — hex-encoded ed25519 private key (never commit real keys)
OPERATOR_KEY=<your_operator_ed25519_private_key_hex>

# Deployed Pool object ID (from `sui client publish` output)
POOL_OBJECT_ID=<deployed_pool_object_id>

# Pool share difficulty scalar (higher = easier shares, more frequent submissions)
INITIAL_DIFFICULTY=1000

# ── Miner sidecar ─────────────────────────────────────────────────────────────

# Address of the upstream Stratum pool (point this at the stratum-bridge)
POOL_HOST=pool.example.com
POOL_PORT=3333

# Local port the sidecar listens on — point your ASIC at this
SIDECAR_PORT=3334

# Miner's own Sui private key — this signs all on-chain share submissions
# Each miner generates their own key: `sui keytool generate ed25519`
MINER_KEY=<your_miner_ed25519_private_key_hex>

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error
RUST_LOG=info
