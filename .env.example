# ── Pool operator (stratum-bridge) ────────────────────────────────────────────

# Stratum server listen address
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3333

# Sui network (devnet)
SUI_RPC_URL=https://fullnode.devnet.sui.io:443

# Operator credentials — bech32 Sui private key (output of `sui keytool export`)
# Format: suiprivkey1...  (never commit real keys — this file is safe to commit)
OPERATOR_KEY=<suiprivkey_from_sui_keytool_export>

# Deployed contract IDs (from `sui client publish --gas-budget 200000000 contracts/`)
POOL_OBJECT_ID=<deployed_pool_object_id>
PACKAGE_ID=<deployed_package_id>

# SUI reward added to pool treasury per job posting, in MIST (1 SUI = 1_000_000_000)
# Default: 100_000_000 MIST = 0.1 SUI per job
REWARD_MIST=100000000

# Floor difficulty for VARDIFF — miners never mine below this value.
# For Avalon Nano/Mini on mainnet, 512 gives a manageable initial rate.
INITIAL_DIFFICULTY=512

# VARDIFF target: how many shares per minute across all connected miners.
# Higher = more frequent on-chain submissions (higher SUI gas cost).
TARGET_SHARES_PER_MIN=10

# ── Bitcoin Core RPC ───────────────────────────────────────────────────────────

# Full node JSON-RPC endpoint (the node running on the external drive)
BITCOIN_RPC_URL=http://127.0.0.1:8332

# Bitcoin Core RPC credentials (set in bitcoin.conf: rpcuser / rpcpassword)
BITCOIN_RPC_USER=<your_rpc_username>
BITCOIN_RPC_PASS=<your_rpc_password>

# How often to poll getblocktemplate for new jobs (seconds)
# Lower = more responsive to new blocks; higher = fewer on-chain posts
JOB_REFRESH_SECS=30

# ── Miner sidecar ─────────────────────────────────────────────────────────────

# Address of the upstream Stratum pool (the stratum-bridge machine on your LAN)
POOL_HOST=192.168.1.10
POOL_PORT=3333

# Local port the sidecar listens on — configure Avalon to point here
SIDECAR_PORT=3334

# Miner's own Sui private key — signs all on-chain share submissions and registration
# Each miner generates their own: `sui keytool generate ed25519`
# Export: `sui keytool export --key-identity <address>`
MINER_KEY=<suiprivkey_from_sui_keytool_export>

# Same contract IDs as the operator section above
# POOL_OBJECT_ID and PACKAGE_ID are shared with the sidecar

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error
RUST_LOG=info
