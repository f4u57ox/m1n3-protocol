# Stratum bridge configuration
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3333

# Sui network
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Operator credentials (never commit real keys)
OPERATOR_KEY=<your_ed25519_private_key_hex>
POOL_OBJECT_ID=<deployed_pool_object_id>

# Mining parameters
INITIAL_DIFFICULTY=1000

# Logging (trace | debug | info | warn | error)
RUST_LOG=info
